[Arguments]
ProjectFileName
\par\tab 
[Begin List]
[Begin List]
\par\tab UpperLeftX
[as Integer]
\par\tab UpperLeftY
[as Integer]
\par\tab Width
[as Integer]
\par\tab Height
[as Integer]
\par\tab Color
[as Integer]
[End List]
\par\tab ...
[End List]




