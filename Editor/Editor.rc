IDR_TOOLBOX MENU 
BEGIN
    POPUP "ToolBox", INACTIVE
    BEGIN
        MENUITEM "Pointer",                     ID_TOOLBOX_POINTER
        MENUITEM "Label",                       ID_TOOLBOX_LABEL
        MENUITEM "TextButton",                  ID_TOOLBOX_TEXTBUTTON
        MENUITEM "GraphicButton",               ID_TOOLBOX_GRAPHICBUTTON
        MENUITEM "Frame",                       ID_TOOLBOX_FRAME
        MENUITEM "TextBox",                     ID_TOOLBOX_TEXTBOX
        MENUITEM "CheckBox",                    ID_TOOLBOX_CHECKBOX
        MENUITEM "Option",                      ID_TOOLBOX_OPTION
        MENUITEM "ComboBox",                    ID_TOOLBOX_COMBOBOX
        MENUITEM "ListBox",                     ID_TOOLBOX_LISTBOX
        MENUITEM "ScrollBar",                   ID_TOOLBOX_SCROLLBAR
        MENUITEM "Slider",                      ID_TOOLBOX_SLIDER
        MENUITEM "PictureBox",                  ID_TOOLBOX_PICTUREBOX
        MENUITEM "Tabs",                        ID_TOOLBOX_TABS
        MENUITEM "MonthPicker",                 ID_TOOLBOX_MONTHPICKER
        MENUITEM "Tree",                        ID_TOOLBOX_TREE
        MENUITEM "Rectangle",                   ID_TOOLBOX_RECTANGLE
        MENUITEM "ProgressBar",                 ID_TOOLBOX_PROGRESSBAR
        MENUITEM "SpinButton",                  ID_TOOLBOX_SPINBUTTON
        MENUITEM "UrlLink",                     ID_TOOLBOX_URLLINK
        MENUITEM "AngleSlider",                 ID_TOOLBOX_ANGLESLIDER
        MENUITEM "BlockView",                   ID_TOOLBOX_BLOCKVIEW
        MENUITEM "SlideView",                   ID_TOOLBOX_SLIDEVIEW
        MENUITEM "Html",                        ID_TOOLBOX_HTML
        MENUITEM "DwgPreview",                  ID_TOOLBOX_DWGPREVIEW
        MENUITEM "ListView",                    ID_TOOLBOX_LISTVIEW
        MENUITEM "BlockList",                   ID_TOOLBOX_BLOCKLIST
        MENUITEM "OptionList",                  ID_TOOLBOX_OPTIONLIST
        MENUITEM "ActiveX",                     ID_TOOLBOX_ACTIVEX
        MENUITEM "DwgList",                     ID_TOOLBOX_DWGLIST
        MENUITEM "ImageList",                   ID_TOOLBOX_IMAGELIST
        MENUITEM "Animation",                   ID_TOOLBOX_ANIMATION
        MENUITEM "Grid",                        ID_TOOLBOX_GRID
        MENUITEM "Splitter",                    ID_TOOLBOX_SPLITTER
        MENUITEM "Hatch",                       ID_TOOLBOX_HATCH
    END
    POPUP "ZOrderItems"
    BEGIN
        MENUITEM "&Bring to Front",             ID_BRINGTOFRONT
        MENUITEM "&Send to Back",               ID_SENDTOBACK
        MENUITEM "Move Forward By 1",           ID_MOVEZFRONTBY1
        MENUITEM "Move Back By 1",              ID_MOVEZBACKBY1
        MENUITEM "Help",                        ID_ZORDERHELP
    END
END

IDR_POPUPMENUS_STD MENU 
BEGIN
    POPUP "&Projects"
    BEGIN
        MENUITEM "&Add Modal Form",             ID_ADDMODAL
        MENUITEM "Add &Modeless Form",          ID_ADDMODELESS
        MENUITEM SEPARATOR
        MENUITEM "&Set AutoLISP File Name",     ID_SETAUTOLISPFILENAME
        MENUITEM SEPARATOR
        MENUITEM "&Remove Form",                ID_REMOVE
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM "&Delete\tDel",                ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "&Bring to Front",             ID_BRINGTOFRONT
        MENUITEM "&Send to Back",               ID_SENDTOBACK
        MENUITEM SEPARATOR
        MENUITEM "&Properties",                 ID_PROPERTIES
        MENUITEM "&Intelligent Help",           ID_EDIT_OBJECTBROWSER
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "&Intelligent Help",           ID_EDIT_OBJECTBROWSER
    END
    POPUP "Projects2"
    BEGIN
        MENUITEM "&Add Modal Form",             ID_ADDMODAL
        MENUITEM "Add &Modeless Form",          ID_ADDMODELESS
    END
END

