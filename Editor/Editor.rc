IDR_MAINFRAME MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "Create Distribution File",    ID_FILE_CREATEDISTFILE
        MENUITEM "&Register Controls...",       ID_FILE_REGISTERCONTROLS
        MENUITEM SEPARATOR
        MENUITEM "Recent File",                 ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar",                    ID_VIEW_TOOLBAR
        MENUITEM "Tool&Box",                    ID_DOCK_TOOLBOX
        MENUITEM "&Z/Tab Order",                ID_DOCK_ZORDER
        MENUITEM "Project Tree",                ID_DOCK_PROJECT
        MENUITEM "Properties",                  ID_DOCK_PROPERTIES
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Help Topics",                ID_HELP_FINDER
        MENUITEM SEPARATOR
        MENUITEM "&About ObjectDCL...",         ID_APP_ABOUT
    END
END

