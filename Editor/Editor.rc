/////////////////////////////////////////////////////////////////////////////
//
// String Table
//

STRINGTABLE 
BEGIN
    IDS_BUTTONSTYLE1        "This setting indicates that the button will act as a 'Cool' button. This means the button will behave just as the buttons in Internet Explorer do."
    IDS_BUTTONSTYLE2        "This setting indicates that the button will have the AutoCAD pick picture displayed."
    IDS_BUTTONSTYLE3        "This setting indicates that the button will have the AutoCAD select picture displayed."
    IDS_BUTTONSTYLE4        "This setting indicates that the button will have the AutoCAD filter picture displayed."
    IDS_BUTTONSTYLE5        "This setting indicates that the button will not display any border of any kind."
    IDS_PROJECT             "Project"
    IDS_MODALFORM           "Modal Forms"
    IDS_MODELESSFORM        "Modeless Forms"
    IDS_DOCKABLEFORM        "Dockable Forms"
    IDS_CONFIGTAB           "Config Tabs"
    IDS_TOOLBOX             "ToolBox"
    IDR_MAINFRAME           "ObjectDCL"
    IDR_OBJECTTYPE          "\nProject\nObjectDCL\nObjectDCL Projects (*.odc)\n.odc\nObjectDCL.Document\nObjectDCL Project"
    IDS_ZTABORDER           "Z / Tab Order"
    IDS_TTTSENDTOBACK       "Send Control To Back of Z/Tab Order"
    IDS_TTTBRINGTOFRONT     "Bring Control To Front of Z/Tab Order"
END

STRINGTABLE 
BEGIN
    IDS_EVENTPREFIXON       "On"
