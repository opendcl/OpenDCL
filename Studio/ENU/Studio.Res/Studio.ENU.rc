/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "Recent File",                 ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM "&Delete\tDel",                ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "&Bring to Front",             ID_SENDTOFRONT
        MENUITEM "&Send to Back",               ID_SENDTOBACK
        MENUITEM SEPARATOR
        MENUITEM "&Properties",                 ID_PROPERTIES
        MENUITEM "&Intelligent Help",           ID_OBJECTBROWSER
        MENUITEM "ActiveX Object Wizard",       ID_AXPROPERTIES
    END
    POPUP "&Project"
    BEGIN
        MENUITEM "&Add Modal Form",             ID_ADDMODAL
        MENUITEM "Add &Modeless Form",          ID_ADDMODELESS
        MENUITEM "Add &Dockable Form",          ID_ADDDOCKABLE
        MENUITEM "Add &Config Tab",             ID_ADDCONFIG
        MENUITEM "Add &File Dialog Box",        ID_ADDFILEDIALOGBOX
        MENUITEM SEPARATOR
        MENUITEM "&View/Edit Picture Folder",   ID_PICTUREFOLDER
        MENUITEM "&Set AutoLISP File Name",     ID_SETAUTOLISPFILENAME
        MENUITEM "Set Project &Password",       ID_SETPROJECTPASSWORD
        MENUITEM SEPARATOR
        MENUITEM "&Remove Form",                ID_REMOVEFORM
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Default Font",               ID_TOOLS_DEFAULTFONT
        MENUITEM "&Grid Spacing",               ID_TOOLS_GRIDSPACING
        MENUITEM SEPARATOR
        MENUITEM "&Set Lisp Symbol Names",      ID_TOOLS_SETLISPSYMBOLNAMES
        MENUITEM "&Clear Lisp Symbol Names",    ID_TOOLS_CLEARLISPSYMBOLNAMES
        MENUITEM SEPARATOR
        MENUITEM "Copy &Events to Clipboard",   ID_TOOLS_EVENTSCOPYTOCLIPBOARD
        MENUITEM "&Write Events to Lisp File",  ID_TOOLS_EVENTSWRITETOLISPFILE
        MENUITEM SEPARATOR
        MENUITEM "&Register Controls...",       ID_TOOLS_REGISTERCONTROLS
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Main Toolbar",               ID_VIEW_TOOLBAR
        MENUITEM "&Font Toolbar",               ID_VIEW_FONTTOOLBAR
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM "Tool&box",                    ID_VIEW_TOOLBOX
        MENUITEM "&Z/Tab Order",                ID_VIEW_ZORDER
        MENUITEM "&Project",                    ID_VIEW_PROJECT
        MENUITEM "Pr&operties",                 ID_VIEW_PROPERTIES
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "&New Window",                 ID_WINDOW_NEW
        MENUITEM "Next &Form",                  ID_WINDOW_NEXTFORM
        MENUITEM "&Previous Form",              ID_WINDOW_PREVFORM
        MENUITEM "&Close",                      ID_WINDOW_CLOSE
        MENUITEM "Close &All",                  ID_WINDOW_CLOSEALL
        MENUITEM "Casca&de",                    ID_WINDOW_CASCADE
        MENUITEM "&Tile",                       ID_WINDOW_TILE_HORZ
        MENUITEM "&Arrange Icons",              ID_WINDOW_ARRANGE
        MENUITEM "&Minimize",                   AFX_IDS_SCMINIMIZE
        MENUITEM "Ma&ximize",                   AFX_IDS_SCMAXIMIZE
        MENUITEM "&Restore",                    AFX_IDS_SCRESTORE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Help",                       ID_HELP
        MENUITEM SEPARATOR
        MENUITEM "&About OpenDCL...",           ID_APP_ABOUT
    END
END

IDR_TOOLBOX MENU 
BEGIN
    POPUP "ToolBox", INACTIVE
    BEGIN
        MENUITEM "Pointer",                     ID_TOOLBOX_POINTER
        MENUITEM "Label",                       ID_TOOLBOX_LABEL
        MENUITEM "TextButton",                  ID_TOOLBOX_TEXTBUTTON
        MENUITEM "GraphicButton",               ID_TOOLBOX_GRAPHICBUTTON
        MENUITEM "Frame",                       ID_TOOLBOX_FRAME
        MENUITEM "TextBox",                     ID_TOOLBOX_TEXTBOX
        MENUITEM "CheckBox",                    ID_TOOLBOX_CHECKBOX
        MENUITEM "Option",                      ID_TOOLBOX_OPTION
        MENUITEM "ComboBox",                    ID_TOOLBOX_COMBOBOX
        MENUITEM "ListBox",                     ID_TOOLBOX_LISTBOX
        MENUITEM "ScrollBar",                   ID_TOOLBOX_SCROLLBAR
        MENUITEM "Slider",                      ID_TOOLBOX_SLIDER
        MENUITEM "PictureBox",                  ID_TOOLBOX_PICTUREBOX
        MENUITEM "Tabs",                        ID_TOOLBOX_TABS
        MENUITEM "MonthPicker",                 ID_TOOLBOX_MONTHPICKER
        MENUITEM "Tree",                        ID_TOOLBOX_TREE
        MENUITEM "Rectangle",                   ID_TOOLBOX_RECTANGLE
        MENUITEM "ProgressBar",                 ID_TOOLBOX_PROGRESSBAR
        MENUITEM "SpinButton",                  ID_TOOLBOX_SPINBUTTON
        MENUITEM "UrlLink",                     ID_TOOLBOX_URLLINK
        MENUITEM "AngleSlider",                 ID_TOOLBOX_ANGLESLIDER
        MENUITEM "BlockView",                   ID_TOOLBOX_BLOCKVIEW
        MENUITEM "SlideView",                   ID_TOOLBOX_SLIDEVIEW
        MENUITEM "Html",                        ID_TOOLBOX_HTML
        MENUITEM "DwgPreview",                  ID_TOOLBOX_DWGPREVIEW
        MENUITEM "ListView",                    ID_TOOLBOX_LISTVIEW
        MENUITEM "BlockList",                   ID_TOOLBOX_BLOCKLIST
        MENUITEM "OptionList",                  ID_TOOLBOX_OPTIONLIST
        MENUITEM "ActiveX",                     ID_TOOLBOX_ACTIVEX
        MENUITEM "DwgList",                     ID_TOOLBOX_DWGLIST
        MENUITEM "ImageList",                   ID_TOOLBOX_IMAGECOMBOBOX
        MENUITEM "Animation",                   ID_TOOLBOX_ANIMATION
        MENUITEM "Grid",                        ID_TOOLBOX_GRID
        MENUITEM "Splitter",                    ID_TOOLBOX_SPLITTER
        MENUITEM "Hatch",                       ID_TOOLBOX_HATCH
    END
    POPUP "ZOrderItems"
    BEGIN
        MENUITEM "&Bring to Front",             ID_SENDTOFRONT
        MENUITEM "&Send to Back",               ID_SENDTOBACK
        MENUITEM "Move Forward By 1",           ID_MOVEZFRONTBY1
        MENUITEM "Move Back By 1",              ID_MOVEZBACKBY1
        MENUITEM "Help",                        ID_ZORDERHELP
    END
END

IDR_POPUPMENUS MENU 
BEGIN
    POPUP "AddForm"
    BEGIN
        MENUITEM "&Add Modal Form",             ID_ADDMODAL
        MENUITEM "Add &Modeless Form",          ID_ADDMODELESS
        MENUITEM "Add &Dockable Form",          ID_ADDDOCKABLE
        MENUITEM "Add &Config Tab",             ID_ADDCONFIG
        MENUITEM "Add &File Dialog Box",        ID_ADDFILEDIALOGBOX
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM "&Delete\tDel",                ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "&Bring to Front",             ID_SENDTOFRONT
        MENUITEM "&Send to Back",               ID_SENDTOBACK
        MENUITEM SEPARATOR
        MENUITEM "&Properties",                 ID_PROPERTIES
        MENUITEM "&Intelligent Help",           ID_OBJECTBROWSER
        MENUITEM "ActiveX Object Wizard",       ID_AXPROPERTIES
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "&Intelligent Help",           ID_OBJECTBROWSER
    END
END


