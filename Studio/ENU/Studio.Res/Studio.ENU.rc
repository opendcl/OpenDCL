IDR_MAINFRAME ACCELERATORS 
BEGIN
    VK_F1,          ID_CONTEXT_HELP,        VIRTKEY, SHIFT, NOINVERT
    "C",            ID_EDIT_COPY,           VIRTKEY, CONTROL, NOINVERT
    VK_INSERT,      ID_EDIT_COPY,           VIRTKEY, CONTROL, NOINVERT
    "X",            ID_EDIT_CUT,            VIRTKEY, CONTROL, NOINVERT
    VK_DELETE,      ID_EDIT_DELETE,         VIRTKEY, NOINVERT
    "V",            ID_EDIT_PASTE,          VIRTKEY, CONTROL, NOINVERT
    VK_INSERT,      ID_EDIT_PASTE,          VIRTKEY, SHIFT, NOINVERT
    VK_BACK,        ID_EDIT_UNDO,           VIRTKEY, ALT, NOINVERT
    "Z",            ID_EDIT_UNDO,           VIRTKEY, CONTROL, NOINVERT
    "N",            ID_FILE_NEW,            VIRTKEY, CONTROL, NOINVERT
    "O",            ID_FILE_OPEN,           VIRTKEY, CONTROL, NOINVERT
    "S",            ID_FILE_SAVE,           VIRTKEY, CONTROL, NOINVERT
    VK_F1,          ID_HELP,                VIRTKEY, NOINVERT
    VK_DOWN,        ID_SHIFTDOWN,           VIRTKEY, NOINVERT
    VK_LEFT,        ID_SHIFTLEFT,           VIRTKEY, NOINVERT
    VK_RIGHT,       ID_SHIFTRIGHT,          VIRTKEY, NOINVERT
    VK_UP,          ID_SHIFTUP,             VIRTKEY, NOINVERT
    VK_F6,          ID_WINDOW_NEXTFORM,     VIRTKEY, NOINVERT
    VK_F6,          ID_WINDOW_PREVFORM,     VIRTKEY, SHIFT, NOINVERT
    VK_ESCAPE,      ID_SELECTPOINTERTOOL,   VIRTKEY, NOINVERT
END


