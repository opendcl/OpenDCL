<CONTROL>
\par\tab NewString
[as String]
\par\tab Image
[as Integer]
\par\tab SelectedImage
[as Integer]
\par\tab\i{Optional} \i0 Indent
[as Integer]
\par\tab\i{Optional} \i0 Index
[as Integer]


